    <worksheet name='Histogram'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontsize='24'>Distribution Of Order Discounts</run>
            <run fontalignment='1'>Æ&#10;&#10;</run>
            <run fontalignment='1' fontcolor='#555555' fontsize='14' italic='true'>Largest distribution of discounts sits between 0.00 - 0.10 and 0.10 - 0.20. There are scantly distributed discounts from 0.40 to 0.90. </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders+ (Sample - Superstore for Tableau 9.x versions)' name='federated.0sfutsh15im0yj1cci9zn1c3cl0x' />
